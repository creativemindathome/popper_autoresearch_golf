digraph KnowledgeGraph {
  graph [rankdir=LR, bgcolor="#ffffff", fontname="Helvetica", fontsize=10, labelloc="t", labeljust="l", nodesep="0.15", ranksep="0.25", splines="ortho", overlap="false", pad="0.1"];
  node [fontname="Helvetica", fontsize=10, margin="0.10,0.07"];
  edge [color="#adb5bd", arrowsize="0.6", penwidth="1"];

  label="Data Pipeline";

  "node_root_data_pipeline" [shape="box", style="rounded,filled,bold", fillcolor="#fff9db", color="#e67700", fontcolor="#212529", penwidth="2", label=<<B>Data Pipeline</B>>, tooltip="Controls how raw text/code becomes token sequences presented to the model. Choices here shape distribution, context construction, and the effective learning signal under a fixed compute budget."];
  "node_data_sources" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Data Sources</B>>, tooltip="Determines the domains and genres the model observes during training. Source composition controls coverage, bias, and the kind of generalization the model can learn."];
  "node_data_source_web_text" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Web Text</B><BR/><FONT POINT-SIZE="9">Mem:0.2MB</FONT>>, tooltip="Broad natural-language text from the web provides diverse topics and writing styles. It tends to increase general knowledge but can introduce noise and duplication."];
  "node_data_source_code" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Code</B><BR/><FONT POINT-SIZE="9">Mem:0.2MB</FONT>>, tooltip="Programming language corpora emphasize syntax, long-range dependencies, and precise token patterns. Code data often improves reasoning-like behaviors at small model sizes."];
  "node_data_source_books" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Books / Long-Form</B><BR/><FONT POINT-SIZE="9">Mem:0.2MB</FONT>>, tooltip="Long-form text increases exposure to extended discourse structure and narrative coherence. It can help models learn longer-context patterns even with limited context windows."];
  "node_data_source_synthetic" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Synthetic / Generated Data</B><BR/><FONT POINT-SIZE="9">Mem:0.3MB</FONT>>, tooltip="Synthetic data can target specific skills or failure modes by generating curated examples. It risks distribution shift or error amplification if generation quality is low."];
  "node_data_cleaning" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Cleaning &amp; Filtering</B>>, tooltip="Removes low-quality, duplicated, or harmful text before training. Better filtering usually increases effective data quality without increasing parameters."];
  "node_data_dedup" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Deduplication</B><BR/><FONT POINT-SIZE="9">Mem:0.1MB</FONT>>, tooltip="Detects and removes near-duplicate documents or passages to reduce memorization and wasted steps. This increases data efficiency at fixed compute."];
  "node_data_language_id" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Language ID Filter</B><BR/><FONT POINT-SIZE="9">Mem:0.1MB</FONT>>, tooltip="Keeps only target languages (or mixes them deliberately) to control distribution. It reduces accidental multilingual drift in a tiny model."];
  "node_data_quality_filter" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Quality Scoring Filter</B><BR/><FONT POINT-SIZE="9">Mem:0.1MB</FONT>>, tooltip="Uses heuristics or learned scoring to prioritize coherent, information-dense text. It effectively increases signal-to-noise ratio without changing architecture."];
  "node_data_toxicity_filter" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Safety / Toxicity Filter</B><BR/><FONT POINT-SIZE="9">Mem:0.1MB</FONT>>, tooltip="Removes or down-weights content associated with harmful or toxic language. It improves behavioral robustness with negligible model-side cost."];
  "node_data_tokenization" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Tokenization</B>>, tooltip="Maps text into discrete tokens that define the model's input/output alphabet. Token choices affect sequence lengths, embedding size, and downstream memory/parameter budgets."];
  "node_tokenizer_bpe" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>BPE (Subword)</B><BR/><FONT POINT-SIZE="9">Mem:0.2MB</FONT>>, tooltip="Byte Pair Encoding learns a subword vocabulary that balances token count and coverage. It is a standard choice for compact tokenization at scale."];
  "node_tokenizer_unigram" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Unigram (SentencePiece)</B><BR/><FONT POINT-SIZE="9">Mem:0.2MB</FONT>>, tooltip="Unigram tokenization chooses tokens via a probabilistic model, often yielding more flexible segmentations. It can reduce brittleness to rare substrings."];
  "node_tokenizer_bytelevel_bpe" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Byte-level BPE</B><BR/><FONT POINT-SIZE="9">Mem:0.25MB</FONT>>, tooltip="Operates on bytes before merging into subwords, ensuring full coverage of arbitrary text. It often increases sequence length slightly but avoids unknown tokens."];
  "node_tokenizer_character" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Character-level</B><BR/><FONT POINT-SIZE="9">Mem:0.3MB</FONT>>, tooltip="Uses characters as tokens, guaranteeing coverage but producing much longer sequences. This typically increases activation/KV-cache memory for a fixed context length."];
  "node_data_sequence_construction" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Sequence Construction</B>>, tooltip="Defines how tokens are packed into fixed-length training sequences. Packing strategy changes utilization, padding waste, and effective batch size under memory limits."];
  "node_sequence_packing" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Packing Strategy</B>>, tooltip="Controls how multiple documents are concatenated or separated to fill context windows. Better packing increases tokens-per-step at the same memory cost."];
  "node_packing_concat_fixed" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Fixed Concat + Padding</B><BR/><FONT POINT-SIZE="9">Mem:0.1MB</FONT>>, tooltip="Concatenates samples into fixed-size blocks with padding where needed. Simple to implement but can waste compute on padding tokens."];
  "node_packing_dynamic" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Dynamic Packing</B><BR/><FONT POINT-SIZE="9">Mem:0.15MB</FONT>>, tooltip="Dynamically packs variable-length samples to minimize padding and maximize real tokens per batch. This improves throughput under strict memory budgets."];
  "node_context_length" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Context Length</B>>, tooltip="Sets the maximum number of tokens processed per forward pass. Memory scales roughly linearly for activations and KV cache, making this a key Parameter Golf lever."];
  "node_context_256" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>256 Tokens</B><BR/><FONT POINT-SIZE="9">Mem:40MB</FONT>>, tooltip="Short context reduces activation and KV-cache memory, enabling larger batch sizes or wider models. It can hurt tasks requiring long-range dependencies."];
  "node_context_512" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>512 Tokens</B><BR/><FONT POINT-SIZE="9">Mem:80MB</FONT>>, tooltip="Moderate context is a common tradeoff between long-range modeling and memory cost. It keeps KV cache manageable while retaining some long-context capacity."];
  "node_context_1024" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>1024 Tokens</B><BR/><FONT POINT-SIZE="9">Mem:160MB</FONT>>, tooltip="Long context increases both activation memory and KV cache substantially. This often forces reductions in model width/depth under a fixed memory ceiling."];
  "node_data_sampling_batching" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Sampling &amp; Batching</B>>, tooltip="Determines how examples are selected and grouped into batches. Batching decisions affect gradient noise, throughput, and peak memory during training."];
  "node_batching_random" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Random Sampling</B><BR/><FONT POINT-SIZE="9">Mem:0.1MB</FONT>>, tooltip="Samples sequences uniformly or with simple weights, producing diverse batches. It is robust but can incur padding inefficiency with variable lengths."];
  "node_batching_length_bucketed" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Length-bucketed Batching</B><BR/><FONT POINT-SIZE="9">Mem:0.15MB</FONT>>, tooltip="Groups sequences of similar length to minimize padding and wasted compute. This increases effective tokens-per-step under a fixed memory budget."];
  "node_data_augmentation" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Data Augmentation</B>>, tooltip="Applies transformations that change the training distribution without adding parameters. Augmentation can improve robustness but must preserve label semantics for next-token prediction."];
  "node_aug_span_corruption" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Span Corruption / Masking</B><BR/><FONT POINT-SIZE="9">Mem:0.2MB</FONT>>, tooltip="Randomly masks contiguous spans and trains the model to predict missing tokens. This can encourage modeling longer dependencies and reduce overfitting."];
  "node_aug_token_dropout" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Token Dropout</B><BR/><FONT POINT-SIZE="9">Mem:0.15MB</FONT>>, tooltip="Randomly drops or replaces tokens during training to discourage reliance on brittle cues. It is a lightweight way to increase robustness at tiny scale."];
  "node_aug_contrastive_crop" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Contrastive Cropping</B><BR/><FONT POINT-SIZE="9">Mem:0.25MB</FONT>>, tooltip="Creates multiple cropped views of the same document to encourage consistent representations. It can help compact models learn invariances but adds pipeline complexity."];
  "node_data_curriculum_mixing" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Curriculum &amp; Mixing</B>>, tooltip="Controls how different data types or difficulties are scheduled over training. Curricula can improve convergence and sample-efficiency without increasing parameters."];
  "node_curriculum_length" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Length Curriculum</B><BR/><FONT POINT-SIZE="9">Mem:0.15MB</FONT>>, tooltip="Starts with shorter sequences and gradually increases context length. This can stabilize early training and manage memory usage over time."];
  "node_mix_dataset_sampling" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Dataset Mixing Weights</B><BR/><FONT POINT-SIZE="9">Mem:0.1MB</FONT>>, tooltip="Adjusts sampling probabilities across corpora to control the effective training distribution. Mixing is a powerful lever for tiny models where capacity is limited."];

  "node_root_data_pipeline" -> "node_data_sources" [];
  "node_data_sources" -> "node_data_source_web_text" [];
  "node_data_sources" -> "node_data_source_code" [];
  "node_data_sources" -> "node_data_source_books" [];
  "node_data_sources" -> "node_data_source_synthetic" [];
  "node_root_data_pipeline" -> "node_data_cleaning" [];
  "node_data_cleaning" -> "node_data_dedup" [];
  "node_data_cleaning" -> "node_data_language_id" [];
  "node_data_cleaning" -> "node_data_quality_filter" [];
  "node_data_cleaning" -> "node_data_toxicity_filter" [];
  "node_root_data_pipeline" -> "node_data_tokenization" [];
  "node_data_tokenization" -> "node_tokenizer_bpe" [];
  "node_data_tokenization" -> "node_tokenizer_unigram" [];
  "node_data_tokenization" -> "node_tokenizer_bytelevel_bpe" [];
  "node_data_tokenization" -> "node_tokenizer_character" [];
  "node_root_data_pipeline" -> "node_data_sequence_construction" [];
  "node_data_sequence_construction" -> "node_sequence_packing" [];
  "node_sequence_packing" -> "node_packing_concat_fixed" [];
  "node_sequence_packing" -> "node_packing_dynamic" [];
  "node_data_sequence_construction" -> "node_context_length" [];
  "node_context_length" -> "node_context_256" [];
  "node_context_length" -> "node_context_512" [];
  "node_context_length" -> "node_context_1024" [];
  "node_root_data_pipeline" -> "node_data_sampling_batching" [];
  "node_data_sampling_batching" -> "node_batching_random" [];
  "node_data_sampling_batching" -> "node_batching_length_bucketed" [];
  "node_root_data_pipeline" -> "node_data_augmentation" [];
  "node_data_augmentation" -> "node_aug_span_corruption" [];
  "node_data_augmentation" -> "node_aug_token_dropout" [];
  "node_data_augmentation" -> "node_aug_contrastive_crop" [];
  "node_root_data_pipeline" -> "node_data_curriculum_mixing" [];
  "node_data_curriculum_mixing" -> "node_curriculum_length" [];
  "node_data_curriculum_mixing" -> "node_mix_dataset_sampling" [];
}
