digraph StandupEvolution {
  graph [rankdir=LR, bgcolor="#fafafa", fontname="Helvetica Neue", label="Knowledge evolution over time\nRun: live_run_20260328_170317\n10 steps • 8 refuted • 0 verified • 2 unknown • ~6.6 min wall", labelloc="t", labeljust="c", fontsize=20, fontcolor="#0f172a", nodesep=0.55, ranksep=1.0, splines=line, pad=0.9, margin=0.4, concentrate=false];
  node [fontname="Helvetica Neue", style="rounded,filled", penwidth=2.5];
  edge [color="#94a3b8", penwidth=5, arrowsize=1.05, minlen=1.8];

