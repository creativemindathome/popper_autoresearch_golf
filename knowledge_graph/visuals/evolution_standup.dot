  h2 [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#64748b">t3 · Refuted</FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="15" COLOR="#b91c1c"><B>✗ 3</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="12" COLOR="#0f172a"><B>gradient-guided-sparse-attention</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="9" COLOR="#b91c1c">REFUTED</FONT></TD></TR></TABLE>>, fillcolor="#fef2f2", color="#b91c1c", width=2.1, height=1.25, penwidth=3];
  h3 [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#64748b">t4 · Refuted</FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="15" COLOR="#b91c1c"><B>✗ 4</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="12" COLOR="#0f172a"><B>fourier-attention-gates</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="9" COLOR="#b91c1c">REFUTED</FONT></TD></TR></TABLE>>, fillcolor="#fef2f2", color="#b91c1c", width=2.1, height=1.25, penwidth=3];
  h4 [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#64748b">t5 · Refuted</FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="15" COLOR="#b91c1c"><B>✗ 5</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="12" COLOR="#0f172a"><B>temporal-depth-modulation</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="9" COLOR="#b91c1c">REFUTED</FONT></TD></TR></TABLE>>, fillcolor="#fef2f2", color="#b91c1c", width=2.1, height=1.25, penwidth=3];
  h5 [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#64748b">t6 · Refuted</FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="15" COLOR="#b91c1c"><B>✗ 6</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="12" COLOR="#0f172a"><B>adaptive-sparse-moe-6</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="9" COLOR="#b91c1c">REFUTED</FONT></TD></TR></TABLE>>, fillcolor="#fef2f2", color="#b91c1c", width=2.1, height=1.25, penwidth=3];
  h6 [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#64748b">t7 · Refuted</FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="15" COLOR="#b91c1c"><B>✗ 7</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="12" COLOR="#0f172a"><B>gradient-informed-attention-v7</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="9" COLOR="#b91c1c">REFUTED</FONT></TD></TR></TABLE>>, fillcolor="#fef2f2", color="#b91c1c", width=2.1, height=1.25, penwidth=3];
  h7 [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#64748b">t8 · Refuted</FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="15" COLOR="#b91c1c"><B>✗ 8</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="12" COLOR="#0f172a"><B>gradient-conditioned-attention-v8</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="9" COLOR="#b91c1c">REFUTED</FONT></TD></TR></TABLE>>, fillcolor="#fef2f2", color="#b91c1c", width=2.1, height=1.25, penwidth=3];
