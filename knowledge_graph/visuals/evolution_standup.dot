  h9 [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#64748b">t10 · Unknown</FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="15" COLOR="#334155"><B>? 10</B></FONT></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="12" COLOR="#0f172a"><B>fractal-depth-transformer</B></FONT></TD></TR></TABLE>>, fillcolor="#f8fafc", color="#334155", width=2.1, height=1.25, penwidth=3];
