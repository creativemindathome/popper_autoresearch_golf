digraph GradedEvolution {
  graph [bgcolor="#ffffff", fontname="Helvetica Neue", labelloc="t", labeljust="center", rankdir=TB, nodesep=0.55, ranksep=1.4, pad=0.8, margin=0.4];
  node [fontname="Helvetica Neue", fontsize=13, margin="0.2,0.15"];
  edge [color="#94a3b8", penwidth=1.2, arrowsize=0.7];

  title_main [shape=plaintext, label=<<TABLE BORDER="0" CELLSPACING="4"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="22"><B>Knowledge evolution — baseline vs new ideas</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="14" COLOR="#475569">10 new hypotheses  •  8 refuted  •  0 verified  •  2 unknown</FONT></TD></TR></TABLE>>];
  legend_box [shape=plaintext, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="4" CELLPADDING="6" ALIGN="LEFT"><TR><TD COLSPAN="3" ALIGN="LEFT" BGCOLOR="#f8fafc"><B>Legend</B></TD></TR><TR><TD WIDTH="28" HEIGHT="18" BGCOLOR="#e5e7eb" BORDER="1" COLOR="#6b7280"></TD><TD COLSPAN="2" ALIGN="LEFT"> Baseline (seed knowledge graph)</TD></TR><TR><TD BORDER="0"></TD><TD COLSPAN="2" ALIGN="LEFT"><FONT POINT-SIZE="11"><B>New hypotheses:</B> run order → stronger fill (same verdict family)</FONT></TD></TR><TR><TD BGCOLOR="#e8e2e6" BORDER="1" COLOR="#b91c1c"></TD><TD BGCOLOR="#f2d7d8" BORDER="1" COLOR="#b91c1c"></TD><TD BGCOLOR="#fecaca" BORDER="1" COLOR="#b91c1c"></TD></TR><TR><TD COLSPAN="3" ALIGN="LEFT"><FONT POINT-SIZE="10">Early  ·  mid-run  ·  latest (example: refuted family)</FONT></TD></TR><TR><TD BGCOLOR="#fecaca" BORDER="1" COLOR="#b91c1c"></TD><TD COLSPAN="2" ALIGN="LEFT"> ❌ Refuted</TD></TR><TR><TD BGCOLOR="#bbf7d0" BORDER="1" COLOR="#15803d"></TD><TD COLSPAN="2" ALIGN="LEFT"> ✓ Verified</TD></TR><TR><TD BGCOLOR="#e2e8f0" BORDER="1" COLOR="#475569"></TD><TD COLSPAN="2" ALIGN="LEFT"> ? Unknown / failed</TD></TR></TABLE>>];
  title_pad [shape=plaintext, label="", width=9.0, height=0.01];
  { rank=same; title_main; title_pad; legend_box; }
  title_main -> title_pad -> legend_box [style=invis, weight=10];

  subgraph cluster_baseline {
    label="Baseline ideas (seed knowledge graph)";
    style="rounded,filled";
    fillcolor="#f9fafb";
    color="#6b7280";
    fontname="Helvetica Neue"; fontsize=15; penwidth=2;
    margin=16;
    "baseline_root_0" [label="Data Pipeline", shape=box, style="rounded,filled", fillcolor="#e5e7eb", color="#6b7280", fontcolor="#374151", fontsize=14, penwidth=2, width=2.8, height=0.65];
    "baseline_root_1" [label="Neural Network", shape=box, style="rounded,filled", fillcolor="#e5e7eb", color="#6b7280", fontcolor="#374151", fontsize=14, penwidth=2, width=2.8, height=0.65];
    "baseline_root_2" [label="Training &amp; Evaluation", shape=box, style="rounded,filled", fillcolor="#e5e7eb", color="#6b7280", fontcolor="#374151", fontsize=14, penwidth=2, width=2.8, height=0.65];
    { rank=same; "baseline_root_0"; "baseline_root_1"; "baseline_root_2"; }
  }

  title_main -> baseline_root_0 [style=invis, weight=100];

  subgraph cluster_new {
    label="New hypotheses (chronological order • colour = age × verdict)";
    style="rounded";
    color="#334155";
    fontname="Helvetica Neue"; fontsize=15; penwidth=2;
    margin=20;
    "hyp_0" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#1 · NN · run position 0%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>entropy-guided-sparse-attention</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#6b7280"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#e5e7eb", color="#6b7280", penwidth=2.5];
    "hyp_1" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#2 · NN · run position 11%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>differential-attention-routing</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#776470"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#e8e2e5", color="#776470", penwidth=2.5];
    "hyp_2" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#3 · NN · run position 22%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>gradient-guided-sparse-attention</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#805a64"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#ebdee1", color="#805a64", penwidth=2.5];
    "hyp_3" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#4 · NN · run position 33%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>fourier-attention-gates</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#895058"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#eedbde", color="#895058", penwidth=2.5];
    "hyp_4" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#5 · NN · run position 44%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>temporal-depth-modulation</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#92464d"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#f1d8da", color="#92464d", penwidth=2.5];
    "hyp_5" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#6 · NN · run position 56%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>adaptive-sparse-moe-6</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#9a3d43"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#f4d5d6", color="#9a3d43", penwidth=2.5];
    "hyp_6" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#7 · NN · run position 67%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>gradient-informed-attention-v7</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#a23539"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#f6d2d3", color="#a23539", penwidth=2.5];
    "hyp_7" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#8 · NN · run position 78%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>gradient-conditioned-attention-v8</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#a92c2f"><B>REFUTED • REFUTED</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#f9cfd0", color="#a92c2f", penwidth=2.5];
    "hyp_8" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#9 · NN · run position 89%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>spiral-attention-h9</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#4a576b"><B>UNKNOWN</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#e2e7ef", color="#4a576b", penwidth=2.5];
    "hyp_9" [label=<<TABLE BORDER="0" CELLSPACING="2"><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="11" COLOR="#475569">#10 · NN · run position 100%</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="15" COLOR="#0f172a"><B>fractal-depth-transformer</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="12" COLOR="#475569"><B>UNKNOWN</B></FONT></TD></TR></TABLE>>, shape=box, style="rounded,filled", fillcolor="#e2e8f0", color="#475569", penwidth=2.5];
    { rank=same; "hyp_0"; "hyp_1"; "hyp_2"; "hyp_3"; }
    { rank=same; "hyp_4"; "hyp_5"; "hyp_6"; "hyp_7"; }
    { rank=same; "hyp_8"; "hyp_9"; }
    hyp_0 -> hyp_1 [style=invis, weight=10];
    hyp_1 -> hyp_2 [style=invis, weight=10];
    hyp_2 -> hyp_3 [style=invis, weight=10];
    hyp_0 -> hyp_4 [style=invis, weight=10];
    hyp_4 -> hyp_5 [style=invis, weight=10];
    hyp_1 -> hyp_5 [style=invis, weight=10];
    hyp_5 -> hyp_6 [style=invis, weight=10];
    hyp_2 -> hyp_6 [style=invis, weight=10];
    hyp_6 -> hyp_7 [style=invis, weight=10];
    hyp_3 -> hyp_7 [style=invis, weight=10];
    hyp_4 -> hyp_8 [style=invis, weight=10];
    hyp_8 -> hyp_9 [style=invis, weight=10];
    hyp_5 -> hyp_9 [style=invis, weight=10];
  }
  baseline_root_1 -> hyp_0 [style=dashed, color="#64748b", penwidth=2, constraint=false, label="new ideas", fontcolor="#64748b", fontsize=10];
}