digraph KnowledgeGraph {
  graph [rankdir=LR, bgcolor="white", fontname="Helvetica", fontsize=10, labelloc="t", nodesep="0.25", ranksep="0.50", splines="spline", overlap="false"];
  node [fontname="Helvetica", fontsize=10, margin="0.07,0.05"];
  edge [color="#868e96", arrowsize="0.6"];

  "node_root_data_pipeline" [shape="box", style="rounded,filled,bold", fillcolor="#fff3bf", color="#b08900", fontcolor="#2b2b2b", penwidth="2", label=<<B>Data Pipeline</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Controls how raw text/code becomes token sequences presented to the model. Choices here shape distribution, context construction, and the effective learning signal under a fixed compute budget."];
  "node_root_neural_network" [shape="box", style="rounded,filled,bold", fillcolor="#fff3bf", color="#b08900", fontcolor="#2b2b2b", penwidth="2", label=<<B>Neural Network</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Defines the parameterized function that maps tokens to next-token probabilities. Under Parameter Golf, architecture choices must trade off accuracy against strict parameter and memory ceilings."];
  "node_root_training_eval" [shape="box", style="rounded,filled,bold", fillcolor="#fff3bf", color="#b08900", fontcolor="#2b2b2b", penwidth="2", label=<<B>Training &amp; Evaluation</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Specifies how the model is optimized and scored, including loss design, optimizer state, precision, and benchmark harness constraints. These choices strongly affect peak memory and convergence at small scale."];
  "node_data_sources" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Data Sources</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Determines the domains and genres the model observes during training. Source composition controls coverage, bias, and the kind of generalization the model can learn."];
  "node_data_source_web_text" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Web Text</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Broad natural-language text from the web provides diverse topics and writing styles. It tends to increase general knowledge but can introduce noise and duplication."];
  "node_data_source_code" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Code</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Programming language corpora emphasize syntax, long-range dependencies, and precise token patterns. Code data often improves reasoning-like behaviors at small model sizes."];
  "node_data_source_books" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Books / Long-Form</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Long-form text increases exposure to extended discourse structure and narrative coherence. It can help models learn longer-context patterns even with limited context windows."];
  "node_data_source_synthetic" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Synthetic / Generated Data</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.30MB</FONT>>, tooltip="Synthetic data can target specific skills or failure modes by generating curated examples. It risks distribution shift or error amplification if generation quality is low."];
  "node_data_cleaning" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Cleaning &amp; Filtering</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Removes low-quality, duplicated, or harmful text before training. Better filtering usually increases effective data quality without increasing parameters."];
  "node_data_dedup" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Deduplication</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.10MB</FONT>>, tooltip="Detects and removes near-duplicate documents or passages to reduce memorization and wasted steps. This increases data efficiency at fixed compute."];
  "node_data_language_id" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Language ID Filter</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.10MB</FONT>>, tooltip="Keeps only target languages (or mixes them deliberately) to control distribution. It reduces accidental multilingual drift in a tiny model."];
  "node_data_quality_filter" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Quality Scoring Filter</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.10MB</FONT>>, tooltip="Uses heuristics or learned scoring to prioritize coherent, information-dense text. It effectively increases signal-to-noise ratio without changing architecture."];
  "node_data_toxicity_filter" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Safety / Toxicity Filter</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.10MB</FONT>>, tooltip="Removes or down-weights content associated with harmful or toxic language. It improves behavioral robustness with negligible model-side cost."];
  "node_data_tokenization" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Tokenization</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Maps text into discrete tokens that define the model's input/output alphabet. Token choices affect sequence lengths, embedding size, and downstream memory/parameter budgets."];
  "node_tokenizer_bpe" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>BPE (Subword)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Byte Pair Encoding learns a subword vocabulary that balances token count and coverage. It is a standard choice for compact tokenization at scale."];
  "node_tokenizer_unigram" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Unigram (SentencePiece)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Unigram tokenization chooses tokens via a probabilistic model, often yielding more flexible segmentations. It can reduce brittleness to rare substrings."];
  "node_tokenizer_bytelevel_bpe" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Byte-level BPE</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.25MB</FONT>>, tooltip="Operates on bytes before merging into subwords, ensuring full coverage of arbitrary text. It often increases sequence length slightly but avoids unknown tokens."];
  "node_tokenizer_character" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Character-level</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.30MB</FONT>>, tooltip="Uses characters as tokens, guaranteeing coverage but producing much longer sequences. This typically increases activation/KV-cache memory for a fixed context length."];
  "node_data_sequence_construction" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Sequence Construction</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Defines how tokens are packed into fixed-length training sequences. Packing strategy changes utilization, padding waste, and effective batch size under memory limits."];
  "node_sequence_packing" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Packing Strategy</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Controls how multiple documents are concatenated or separated to fill context windows. Better packing increases tokens-per-step at the same memory cost."];
  "node_packing_concat_fixed" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Fixed Concat + Padding</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.10MB</FONT>>, tooltip="Concatenates samples into fixed-size blocks with padding where needed. Simple to implement but can waste compute on padding tokens."];
  "node_packing_dynamic" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Dynamic Packing</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.15MB</FONT>>, tooltip="Dynamically packs variable-length samples to minimize padding and maximize real tokens per batch. This improves throughput under strict memory budgets."];
  "node_context_length" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Context Length</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Sets the maximum number of tokens processed per forward pass. Memory scales roughly linearly for activations and KV cache, making this a key Parameter Golf lever."];
  "node_context_256" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>256 Tokens</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:40.0MB</FONT>>, tooltip="Short context reduces activation and KV-cache memory, enabling larger batch sizes or wider models. It can hurt tasks requiring long-range dependencies."];
  "node_context_512" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>512 Tokens</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:80.0MB</FONT>>, tooltip="Moderate context is a common tradeoff between long-range modeling and memory cost. It keeps KV cache manageable while retaining some long-context capacity."];
  "node_context_1024" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>1024 Tokens</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:160.0MB</FONT>>, tooltip="Long context increases both activation memory and KV cache substantially. This often forces reductions in model width/depth under a fixed memory ceiling."];
  "node_data_sampling_batching" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Sampling &amp; Batching</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Determines how examples are selected and grouped into batches. Batching decisions affect gradient noise, throughput, and peak memory during training."];
  "node_batching_random" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Random Sampling</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.10MB</FONT>>, tooltip="Samples sequences uniformly or with simple weights, producing diverse batches. It is robust but can incur padding inefficiency with variable lengths."];
  "node_batching_length_bucketed" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Length-bucketed Batching</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.15MB</FONT>>, tooltip="Groups sequences of similar length to minimize padding and wasted compute. This increases effective tokens-per-step under a fixed memory budget."];
  "node_data_augmentation" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Data Augmentation</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Applies transformations that change the training distribution without adding parameters. Augmentation can improve robustness but must preserve label semantics for next-token prediction."];
  "node_aug_span_corruption" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Span Corruption / Masking</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Randomly masks contiguous spans and trains the model to predict missing tokens. This can encourage modeling longer dependencies and reduce overfitting."];
  "node_aug_token_dropout" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Token Dropout</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.15MB</FONT>>, tooltip="Randomly drops or replaces tokens during training to discourage reliance on brittle cues. It is a lightweight way to increase robustness at tiny scale."];
  "node_aug_contrastive_crop" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Contrastive Cropping</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.25MB</FONT>>, tooltip="Creates multiple cropped views of the same document to encourage consistent representations. It can help compact models learn invariances but adds pipeline complexity."];
  "node_data_curriculum_mixing" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Curriculum &amp; Mixing</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Controls how different data types or difficulties are scheduled over training. Curricula can improve convergence and sample-efficiency without increasing parameters."];
  "node_curriculum_length" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Length Curriculum</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.15MB</FONT>>, tooltip="Starts with shorter sequences and gradually increases context length. This can stabilize early training and manage memory usage over time."];
  "node_mix_dataset_sampling" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Dataset Mixing Weights</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.10MB</FONT>>, tooltip="Adjusts sampling probabilities across corpora to control the effective training distribution. Mixing is a powerful lever for tiny models where capacity is limited."];
  "node_nn_embeddings" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Embeddings</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Maps discrete tokens into continuous vectors the network can process. Embeddings often dominate parameter count in tiny LLMs because they scale with vocabulary size."];
  "node_nn_embedding_strategy" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Token Embedding Strategy</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Defines how token IDs are converted to vectors and how much parameter budget is allocated to that mapping. Changing this is a common way to free parameters for the backbone."];
  "node_embed_full" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Full Embedding Matrix</B><BR/><FONT POINT-SIZE="9">P:8,000,000 | Mem:12.0MB</FONT>>, tooltip="A learned lookup table mapping each vocabulary token to a dense vector. It is expressive but can consume a large fraction of the parameter budget."];
  "node_embed_factorized" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Factorized Embeddings</B><BR/><FONT POINT-SIZE="9">P:5,000,000 | Mem:12.0MB</FONT>>, tooltip="Represents embeddings as a low-rank factorization to reduce parameters while preserving expressivity. This trades some embedding capacity for parameter headroom."];
  "node_embed_hashing" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Hashed / Shared Embeddings</B><BR/><FONT POINT-SIZE="9">P:2,500,000 | Mem:10.0MB</FONT>>, tooltip="Maps multiple tokens to shared embedding slots via hashing or sharing rules to reduce parameters. This can free significant budget but may introduce collisions that hurt accuracy."];
  "node_nn_positional_encoding" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Positional Encoding</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Injects token position information so the model can distinguish order. Some methods are parameter-free but affect attention behavior and memory scaling with context length."];
  "node_pos_rope" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>RoPE (Rotary)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.50MB</FONT>>, tooltip="Applies a deterministic rotation to query/key vectors based on position, enabling extrapolation to longer contexts. It is parameter-free and common in modern LLMs."];
  "node_pos_alibi" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>ALiBi (Linear Bias)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.50MB</FONT>>, tooltip="Adds a head-dependent linear bias to attention logits that encodes relative positions. It is parameter-free and can improve long-context generalization under budget."];
  "node_pos_absolute" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Learned Absolute Positions</B><BR/><FONT POINT-SIZE="9">P:260,000 | Mem:0.80MB</FONT>>, tooltip="Uses a learned embedding for each position up to the context limit. It adds parameters proportional to context length and can be less robust to extrapolation."];
  "node_nn_transformer" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Transformer Backbone</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Stacks attention and feed-forward blocks to model complex token dependencies. Under Parameter Golf, most innovation lives in reallocating parameter/memory across these sub-components."];
  "node_transformer_block" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Transformer Block</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="A repeated unit combining attention, MLP, normalization, and residual connections. Its internal design determines both parameter efficiency and activation/KV-cache memory."];
  "node_transformer_attention" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Attention</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Computes content-dependent mixing of token representations to model long-range interactions. Attention is memory-heavy due to attention logits/activations and KV cache during inference."];
  "node_attn_projections" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Attention Projections</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Linear layers that produce queries, keys, values, and output projections. Projection parameter count scales roughly with hidden size squared, making it a major budget lever."];
  "node_attn_query_proj" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Query Projection</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5.00MB</FONT>>, tooltip="Projects hidden states into query vectors used to retrieve information from keys/values. Its parameters scale with hidden size and number of layers."];
  "node_attn_key_proj" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Key Projection</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Projects hidden states into key vectors that index information in attention. Key projection can be per-head (more parameters) or shared across heads (fewer parameters)."];
  "node_attn_key_per_head" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Per-head Keys (MHA-style)</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5.00MB</FONT>>, tooltip="Computes distinct key vectors for each attention head, maximizing expressivity. This typically uses more parameters than shared-key variants."];
  "node_attn_key_shared" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Shared Keys (GQA/MQA-style)</B><BR/><FONT POINT-SIZE="9">P:120,000 | Mem:5.00MB</FONT>>, tooltip="Shares key projections across heads or head groups, reducing parameter count. It often trades some expressivity for large memory savings in KV cache during inference."];
  "node_attn_value_proj" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Value Projection</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Projects hidden states into value vectors that carry content aggregated by attention weights. Like keys, values can be per-head or shared to reduce parameters and KV cache."];
  "node_attn_value_per_head" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Per-head Values (MHA-style)</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5.00MB</FONT>>, tooltip="Computes distinct value vectors per head to maximize representational capacity. This uses more parameters and increases KV cache size compared to shared-value variants."];
  "node_attn_value_shared" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Shared Values (GQA/MQA-style)</B><BR/><FONT POINT-SIZE="9">P:120,000 | Mem:5.00MB</FONT>>, tooltip="Shares value projections across heads or head groups, reducing parameter count. It can significantly reduce inference KV cache memory at small parameter budgets."];
  "node_attn_output_proj" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Output Projection</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5.00MB</FONT>>, tooltip="Projects concatenated head outputs back to the model hidden size. It is required for standard multi-head attention and scales with hidden size squared."];
  "node_attn_compute" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Attention Computation</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Computes attention weights and applies them to values. The choice of implementation affects peak activation memory and speed, especially at longer context lengths."];
  "node_attn_softmax_impl" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Softmax Attention Implementation</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Determines how attention logits and softmax are computed and stored. Memory-efficient implementations can reduce peak activation memory without changing parameters."];
  "node_attn_softmax_naive" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Naive / Standard Softmax</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:40.0MB</FONT>>, tooltip="Materializes attention logits/weights more directly, increasing activation memory at long context. It is widely supported but often memory-limited in Parameter Golf settings."];
  "node_attn_softmax_flash" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>FlashAttention-style (Tiled)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:18.0MB</FONT>>, tooltip="Computes attention in tiles to avoid storing full attention matrices. This can sharply reduce peak activation memory while preserving standard softmax attention."];
  "node_attn_kv_cache" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>KV Cache Strategy (Inference)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Stores past keys/values for autoregressive decoding to avoid recomputation. KV cache memory scales with context length and head dimensions, often dominating inference memory."];
  "node_kv_cache_none" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>No KV Cache (Recompute)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Does not store past keys/values, recomputing them each step. This reduces memory but increases compute and can be infeasible for long contexts."];
  "node_kv_cache_fp16" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>FP16/BF16 KV Cache</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:24.0MB</FONT>>, tooltip="Stores keys/values in half precision, balancing fidelity and memory usage. This is a common baseline for inference memory accounting."];
  "node_kv_cache_int8" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>INT8 KV Cache</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:12.0MB</FONT>>, tooltip="Quantizes KV cache to 8-bit representations to reduce memory footprint. This can introduce approximation error but may be critical under strict memory budgets."];
  "node_transformer_mlp" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Feed-Forward Network (MLP)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Applies per-token nonlinear transformations that expand and contract hidden representations. MLP layers often dominate parameter count and a large share of activation memory."];
  "node_mlp_variant" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>MLP Variant</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Chooses the internal structure of the MLP (activation, gating, sparsity, or factorization). This is a prime target for parameter reallocation toward OOD ideas."];
  "node_mlp_dense_fnn" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Dense FFN (ReLU/GELU)</B><BR/><FONT POINT-SIZE="9">P:4,200,000 | Mem:70.0MB</FONT>>, tooltip="Standard two-layer feed-forward network with a pointwise nonlinearity. It is a strong baseline but uses many parameters for a given hidden size."];
  "node_mlp_swiglu" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>SwiGLU (Gated MLP)</B><BR/><FONT POINT-SIZE="9">P:5,200,000 | Mem:80.0MB</FONT>>, tooltip="Uses a gated activation that can improve quality at fixed depth. It often increases parameters slightly versus a dense FFN but can be more compute-efficient per gain."];
  "node_mlp_low_rank" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Low-rank / Factorized MLP</B><BR/><FONT POINT-SIZE="9">P:2,500,000 | Mem:55.0MB</FONT>>, tooltip="Factorizes large MLP matrices into low-rank components to reduce parameters. This can free budget for attention or new modules but may bottleneck capacity."];
  "node_mlp_moe" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Mixture-of-Experts (Sparse)</B><BR/><FONT POINT-SIZE="9">P:8,000,000 | Mem:90.0MB</FONT>>, tooltip="Routes tokens to a subset of expert MLPs, increasing total parameters without proportional compute. It can boost capacity but complicates routing and memory accounting."];
  "node_transformer_norm" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Normalization</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Stabilizes activations and gradients to enable deep training. Normalization has low parameter cost but strongly affects optimization dynamics in small models."];
  "node_norm_layernorm" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>LayerNorm</B><BR/><FONT POINT-SIZE="9">P:10,000 | Mem:1.00MB</FONT>>, tooltip="Normalizes activations using mean and variance across hidden dimensions with learned gain/bias. It is widely used but can be slower than RMSNorm in some kernels."];
  "node_norm_rmsnorm" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>RMSNorm</B><BR/><FONT POINT-SIZE="9">P:8,000 | Mem:0.80MB</FONT>>, tooltip="Normalizes by root-mean-square without subtracting the mean, typically using only a learned gain. It can be more parameter- and compute-efficient while remaining stable."];
  "node_transformer_residual" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Residual Connections</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:1.00MB</FONT>>, tooltip="Adds skip connections that improve gradient flow and allow iterative refinement of representations. Residuals add negligible parameters but contribute to activation storage."];
  "node_transformer_dropout" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Dropout</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.50MB</FONT>>, tooltip="Randomly zeroes activations during training to reduce overfitting. It has no parameters but can change optimization behavior and effective capacity in tiny models."];
  "node_nn_output_head" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Output Head</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Maps final hidden states to logits over the vocabulary. The output layer can match embedding size and may rival embeddings in parameter cost unless weights are tied or factorized."];
  "node_head_strategy" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>LM Head Strategy</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Defines how logits are produced, including whether the head is untied, tied to embeddings, or structured to reduce parameters. This is a common place to free parameters under strict budgets."];
  "node_head_untied" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Untied Linear LM Head</B><BR/><FONT POINT-SIZE="9">P:8,000,000 | Mem:10.0MB</FONT>>, tooltip="Uses a separate weight matrix to map hidden states to vocabulary logits. This maximizes flexibility but can nearly double parameters when embeddings are also large."];
  "node_head_weight_tied" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Weight-tied Head (Reuse Embeddings)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:2.00MB</FONT>>, tooltip="Reuses the token embedding matrix as the output projection, reducing parameters and sometimes improving generalization. This is a high-leverage Parameter Golf trick."];
  "node_head_adaptive_softmax" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Adaptive / Factorized Softmax</B><BR/><FONT POINT-SIZE="9">P:4,000,000 | Mem:8.00MB</FONT>>, tooltip="Structures the output distribution to reduce compute and parameters for rare tokens. It can save parameters but adds complexity and may affect benchmark comparability."];
  "node_train_loss" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Loss Function</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Defines the training objective that shapes gradients. Loss modifications can change calibration and stability without adding parameters to the model."];
  "node_loss_cross_entropy" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Cross-Entropy</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Maximizes the likelihood of the next token under the model distribution. It is the standard objective for language modeling and typically parameter-free."];
  "node_loss_label_smoothing" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Label Smoothing</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Blends the one-hot target with a uniform distribution to reduce overconfidence. This can improve generalization and calibration in small models."];
  "node_loss_z_loss" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Z-loss / Logit Penalty</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Adds a penalty to stabilize logits and improve numerical behavior, often helpful with low precision. It can improve training stability without changing model size."];
  "node_train_optimizer" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Optimizer &amp; State</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Controls parameter updates and determines additional optimizer-state memory. Optimizer choice is a major contributor to peak training memory at fixed parameter counts."];
  "node_optimizer_state_strategy" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Optimizer State Strategy</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Represents the extra state stored per parameter (e.g., moments) and its precision. Under tight memory budgets, quantized or factorized states can free memory for larger batches or models."];
  "node_opt_adamw_fp32_state" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>AdamW (FP32 moments)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:120.0MB</FONT>>, tooltip="Stores first and second moment estimates for each parameter, typically in FP32 for stability. This is effective but can dominate training memory for tiny models."];
  "node_opt_adamw_8bit_state" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>AdamW (8-bit moments)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:60.0MB</FONT>>, tooltip="Quantizes optimizer moments to reduce memory while approximating Adam updates. This can significantly lower peak memory with modest accuracy impact when tuned."];
  "node_opt_adafactor" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Adafactor (Factorized)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:40.0MB</FONT>>, tooltip="Approximates second-moment statistics with factored representations to reduce memory. It is often used when optimizer-state memory is the main bottleneck."];
  "node_opt_sgd_momentum" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>SGD + Momentum</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:30.0MB</FONT>>, tooltip="Uses momentum buffers but avoids second-moment estimates, reducing state memory. It can be harder to tune for transformers but is memory-light."];
  "node_train_precision" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Numerical Precision</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Chooses numeric formats for weights, activations, and gradients. Lower precision reduces memory and bandwidth but can require stabilization tricks to train reliably."];
  "node_precision_fp32" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>FP32 Training</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:180.0MB</FONT>>, tooltip="Uses 32-bit floats for most tensors, offering stability at high memory cost. This often violates Parameter Golf memory constraints for longer contexts."];
  "node_precision_fp16_bf16" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>FP16/BF16 Mixed Precision</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:120.0MB</FONT>>, tooltip="Uses half precision for activations/weights with selective FP32 accumulations. It is a standard approach to fit larger models/batches under memory limits."];
  "node_precision_fp8" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>FP8 Activations (Advanced)</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:90.0MB</FONT>>, tooltip="Uses 8-bit floats for some tensors to further reduce memory and bandwidth. It can provide large savings but often needs careful scaling and kernel support."];
  "node_train_activation_storage" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Activation Storage Strategy</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Controls how intermediate activations are stored for backpropagation. Checkpointing can reduce peak memory by recomputing activations at the cost of extra compute."];
  "node_activations_store_all" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Store All Activations</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:120.0MB</FONT>>, tooltip="Keeps forward activations for backpropagation, minimizing recomputation. This is compute-efficient but often hits memory ceilings first."];
  "node_activations_checkpoint" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Gradient Checkpointing</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:60.0MB</FONT>>, tooltip="Recomputes some forward passes during backpropagation instead of storing all activations. This reduces peak memory and can unlock larger batch sizes in Parameter Golf."];
  "node_train_evaluation" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Evaluation Harness</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Defines how the model is scored and constrained, including exact benchmark implementation. A stable harness is required to compare innovations under the same Parameter Golf rules."];
  "node_eval_param_golf" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>OpenAI Parameter Golf Benchmark</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Scores models under strict parameter and memory constraints, preventing trivial scaling. The benchmark incentivizes architectural and optimization innovations that fit tight budgets."];
  "node_train_budget_accounting" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1c7ed6", fontcolor="#2b2b2b", penwidth="1.2", label=<<B>Budget Accounting</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0MB</FONT>>, tooltip="Tracks parameter count and memory usage to enforce constraints and guide component swaps. Accurate accounting enables deliberate tradeoffs rather than accidental OOM failures."];
  "node_budget_parameters" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Parameter Counter</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Computes model parameter count, optionally by component, to ensure compliance with size limits. It enables targeted parameter reallocation toward novel modules."];
  "node_budget_memory" [shape="ellipse", style="filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#2b2b2b", penwidth="1", label=<<B>Peak Memory Estimator</B><BR/><FONT POINT-SIZE="9">P:0 | Mem:0.20MB</FONT>>, tooltip="Estimates peak memory from activations, optimizer state, and KV cache to prevent exceeding constraints. It supports 'swap out' reasoning for memory-heavy components like attention."];

