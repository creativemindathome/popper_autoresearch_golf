  "node_root_data_pipeline" -> "node_data_tokenization" [color="#64748b55", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_bpe" [color="#64748b55", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_unigram" [color="#64748b55", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_bytelevel_bpe" [color="#64748b55", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_character" [color="#64748b55", penwidth=1];
  "node_root_data_pipeline" -> "node_data_sequence_construction" [color="#64748b55", penwidth=1];
  "node_data_sequence_construction" -> "node_sequence_packing" [color="#64748b55", penwidth=1];
  "node_sequence_packing" -> "node_packing_concat_fixed" [color="#64748b55", penwidth=1];
  "node_sequence_packing" -> "node_packing_dynamic" [color="#64748b55", penwidth=1];
  "node_data_sequence_construction" -> "node_context_length" [color="#64748b55", penwidth=1];
  "node_context_length" -> "node_context_256" [color="#64748b55", penwidth=1];
  "node_context_length" -> "node_context_512" [color="#64748b55", penwidth=1];
  "node_context_length" -> "node_context_1024" [color="#64748b55", penwidth=1];
  "node_root_data_pipeline" -> "node_data_sampling_batching" [color="#64748b55", penwidth=1];
  "node_data_sampling_batching" -> "node_batching_random" [color="#64748b55", penwidth=1];
  "node_data_sampling_batching" -> "node_batching_length_bucketed" [color="#64748b55", penwidth=1];
