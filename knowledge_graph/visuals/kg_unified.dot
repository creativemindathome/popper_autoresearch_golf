  // Legend
  subgraph cluster_legend {
    label="Legend";
    style="rounded";
    fillcolor="white";
    color="#94a3b8";
    node [shape=box, style=filled, fontsize=8, width=0.3, height=0.2];
    edge [style=invis];

    "legend_root" [label="Root", fillcolor="#ef4444", shape=circle, width=0.3];
    "legend_branch" [label="Branch", fillcolor="#f87171", shape=circle, width=0.25];
    "legend_leaf" [label="Leaf", fillcolor="#fb923c", shape=circle, width=0.15];
    "legend_hyp" [label="Hypothesis", fillcolor="#fbbf24", style=dashed, shape=ellipse];
    "legend_verified" [label="Verified", fillcolor="#10b981", shape=box, style=rounded];
    "legend_refuted" [label="Refuted", fillcolor="#ef4444", style=dashed, shape=diamond];
    "legend_root" -> "legend_branch" -> "legend_leaf" -> "legend_hyp" -> "legend_verified" -> "legend_refuted";
  }
}
