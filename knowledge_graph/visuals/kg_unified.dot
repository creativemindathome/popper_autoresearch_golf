  "node_data_augmentation" -> "node_aug_token_dropout" [color="#64748b55", penwidth=1];
  "node_data_augmentation" -> "node_aug_contrastive_crop" [color="#64748b55", penwidth=1];
  "node_root_data_pipeline" -> "node_data_curriculum_mixing" [color="#64748b55", penwidth=1];
  "node_data_curriculum_mixing" -> "node_curriculum_length" [color="#64748b55", penwidth=1];
  "node_data_curriculum_mixing" -> "node_mix_dataset_sampling" [color="#64748b55", penwidth=1];
  "node_root_neural_network" -> "node_nn_embeddings" [color="#64748b55", penwidth=1];
  "node_nn_embeddings" -> "node_nn_embedding_strategy" [color="#64748b55", penwidth=1];
