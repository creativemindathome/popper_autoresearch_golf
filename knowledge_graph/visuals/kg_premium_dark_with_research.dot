  "node_transformer_mlp" -> "node_mlp_variant";
  "node_transformer_block" -> "node_transformer_mlp";
  "node_transformer_norm" [label="Normalization", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
