digraph KG {
  graph [bgcolor="#111827", fontname="Inter",
         fontsize=20, labelloc="t", labeljust="center",
         nodesep=0.6, ranksep=2.0, splines="ortho",
         overlap="scale", pad=1.5, margin=0,
         fontcolor="#f9fafb", bgcolor="#111827"];
  node [fontname="Inter", shape=box,
        style="rounded,filled", penwidth=2,
        fontcolor="#f9fafb"];
  edge [color="#374151", arrowsize=0.8, penwidth=1.5,
        dir="forward", arrowhead="normal"];

  label=<<FONT POINT-SIZE="24" FACE="Inter"><B>Parameter Golf: Knowledge Architecture</B></FONT>>;

  "node_root_data_pipeline" [label="Data Pipeline", fillcolor="#60a5fa", width=2.0, height=0.8, fontsize=14, fontcolor="#f9fafb", penwidth=3];
  "node_data_sources" [label="Data Sources", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_data_source_web_text" [label="Web Text", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_sources" -> "node_data_source_web_text";
  "node_data_source_code" [label="Code", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_sources" -> "node_data_source_code";
  "node_data_source_books" [label="Books / Long-Form", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_sources" -> "node_data_source_books";
  "node_data_source_synthetic" [label="Synthetic / Generated Data", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_sources" -> "node_data_source_synthetic";
  "node_root_data_pipeline" -> "node_data_sources";
  "node_data_cleaning" [label="Cleaning & Filtering", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_data_dedup" [label="Deduplication", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_cleaning" -> "node_data_dedup";
  "node_data_language_id" [label="Language ID Filter", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_cleaning" -> "node_data_language_id";
  "node_data_quality_filter" [label="Quality Scoring Filter", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_cleaning" -> "node_data_quality_filter";
  "node_data_toxicity_filter" [label="Safety / Toxicity Filter", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_cleaning" -> "node_data_toxicity_filter";
  "node_root_data_pipeline" -> "node_data_cleaning";
  "node_data_tokenization" [label="Tokenization", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_tokenizer_bpe" [label="BPE (Subword)", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_bpe";
  "node_tokenizer_unigram" [label="Unigram (SentencePiece)", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_unigram";
  "node_tokenizer_bytelevel_bpe" [label="Byte-level BPE", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_bytelevel_bpe";
  "node_tokenizer_character" [label="Character-level", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_tokenization" -> "node_tokenizer_character";
  "node_root_data_pipeline" -> "node_data_tokenization";
  "node_data_sequence_construction" [label="Sequence Construction", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_sequence_packing" [label="Packing Strategy", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_packing_concat_fixed" [label="Fixed Concat + Padding", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_sequence_packing" -> "node_packing_concat_fixed";
  "node_packing_dynamic" [label="Dynamic Packing", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_sequence_packing" -> "node_packing_dynamic";
  "node_data_sequence_construction" -> "node_sequence_packing";
  "node_context_length" [label="Context Length", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_context_256" [label="256 Tokens", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_context_length" -> "node_context_256";
  "node_context_512" [label="512 Tokens", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_context_length" -> "node_context_512";
  "node_context_1024" [label="1024 Tokens", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_context_length" -> "node_context_1024";
  "node_data_sequence_construction" -> "node_context_length";
  "node_root_data_pipeline" -> "node_data_sequence_construction";
  "node_data_sampling_batching" [label="Sampling & Batching", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_batching_random" [label="Random Sampling", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_sampling_batching" -> "node_batching_random";
  "node_batching_length_bucketed" [label="Length-bucketed Batching", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_sampling_batching" -> "node_batching_length_bucketed";
  "node_root_data_pipeline" -> "node_data_sampling_batching";
  "node_data_augmentation" [label="Data Augmentation", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_aug_span_corruption" [label="Span Corruption / Masking", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_augmentation" -> "node_aug_span_corruption";
  "node_aug_token_dropout" [label="Token Dropout", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_augmentation" -> "node_aug_token_dropout";
  "node_aug_contrastive_crop" [label="Contrastive Cropping", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_augmentation" -> "node_aug_contrastive_crop";
  "node_root_data_pipeline" -> "node_data_augmentation";
  "node_data_curriculum_mixing" [label="Curriculum & Mixing", fillcolor="#3b82f6", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_curriculum_length" [label="Length Curriculum", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_curriculum_mixing" -> "node_curriculum_length";
  "node_mix_dataset_sampling" [label="Dataset Mixing Weights", fillcolor="#1e40af", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_data_curriculum_mixing" -> "node_mix_dataset_sampling";
  "node_root_data_pipeline" -> "node_data_curriculum_mixing";

  "node_root_neural_network" [label="Neural Network", fillcolor="#f87171", width=2.0, height=0.8, fontsize=14, fontcolor="#f9fafb", penwidth=3];
  "node_nn_embeddings" [label="Embeddings", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_nn_embedding_strategy" [label="Token Embedding Strategy", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_embed_full" [label="Full Embedding Matrix", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_nn_embedding_strategy" -> "node_embed_full";
  "node_embed_factorized" [label="Factorized Embeddings", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_nn_embedding_strategy" -> "node_embed_factorized";
  "node_embed_hashing" [label="Hashed / Shared Embeddings", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_nn_embedding_strategy" -> "node_embed_hashing";
  "node_nn_embeddings" -> "node_nn_embedding_strategy";
  "node_nn_positional_encoding" [label="Positional Encoding", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
