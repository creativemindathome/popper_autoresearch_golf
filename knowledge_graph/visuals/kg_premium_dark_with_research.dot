  "node_root_training_eval" -> "node_train_activation_storage";
  "node_train_evaluation" [label="Evaluation Harness", fillcolor="#34d399", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_eval_param_golf" [label="OpenAI Parameter Golf Benchmark", fillcolor="#065f46", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_train_evaluation" -> "node_eval_param_golf";
  "node_root_training_eval" -> "node_train_evaluation";
  "node_train_budget_accounting" [label="Budget Accounting", fillcolor="#34d399", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_budget_parameters" [label="Parameter Counter", fillcolor="#065f46", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_train_budget_accounting" -> "node_budget_parameters";
  "node_budget_memory" [label="Peak Memory Estimator", fillcolor="#065f46", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_train_budget_accounting" -> "node_budget_memory";
  "node_root_training_eval" -> "node_train_budget_accounting";

  // Hypotheses
  "hyp_0" [label="Unknown", fillcolor="#fee2e2", color="#ef4444", style="filled,rounded", fontcolor="#ef4444", fontsize=10, width=2.5, height=0.5, penwidth=2];
  "hyp_0" -> "node_root_neural_network" [color="#ef4444", style="dashed", penwidth=1.5, constraint=false];
  "hyp_1" [label="Low-Rank Factorized Transformer Lay...", fillcolor="#fef3c7", color="#f59e0b", style="filled,rounded,dashed", fontcolor="#f59e0b", fontsize=10, width=2.5, height=0.5, penwidth=2];
  "hyp_1" -> "node_root_neural_network" [color="#f59e0b", style="dashed", penwidth=1.5, constraint=false];
  "hyp_2" [label="Unknown", fillcolor="#fee2e2", color="#ef4444", style="filled,rounded", fontcolor="#ef4444", fontsize=10, width=2.5, height=0.5, penwidth=2];
  "hyp_2" -> "node_root_neural_network" [color="#ef4444", style="dashed", penwidth=1.5, constraint=false];
  "hyp_3" [label="Unknown", fillcolor="#fef3c7", color="#f59e0b", style="filled,rounded,dashed", fontcolor="#f59e0b", fontsize=10, width=2.5, height=0.5, penwidth=2];
  "hyp_3" -> "node_root_neural_network" [color="#f59e0b", style="dashed", penwidth=1.5, constraint=false];
}