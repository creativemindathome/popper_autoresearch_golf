  "node_transformer_block" -> "node_transformer_dropout";
  "node_nn_transformer" -> "node_transformer_block";
  "node_root_neural_network" -> "node_nn_transformer";
  "node_nn_output_head" [label="Output Head", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
