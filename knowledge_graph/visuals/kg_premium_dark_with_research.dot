  "node_mlp_dense_fnn" [label="Dense FFN (ReLU/GELU)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_mlp_variant" -> "node_mlp_dense_fnn";
  "node_mlp_swiglu" [label="SwiGLU (Gated MLP)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_mlp_variant" -> "node_mlp_swiglu";
  "node_mlp_low_rank" [label="Low-rank / Factorized MLP", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
