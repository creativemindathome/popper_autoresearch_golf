  "node_nn_positional_encoding" -> "node_pos_rope";
  "node_pos_alibi" [label="ALiBi (Linear Bias)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_nn_positional_encoding" -> "node_pos_alibi";
  "node_pos_absolute" [label="Learned Absolute Positions", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_nn_positional_encoding" -> "node_pos_absolute";
  "node_nn_embeddings" -> "node_nn_positional_encoding";
  "node_root_neural_network" -> "node_nn_embeddings";
  "node_nn_transformer" [label="Transformer Backbone", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_transformer_block" [label="Transformer Block", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_transformer_attention" [label="Attention", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_attn_projections" [label="Attention Projections", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_attn_query_proj" [label="Query Projection", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_projections" -> "node_attn_query_proj";
  "node_attn_key_proj" [label="Key Projection", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_attn_key_per_head" [label="Per-head Keys (MHA-style)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_key_proj" -> "node_attn_key_per_head";
  "node_attn_key_shared" [label="Shared Keys (GQA/MQA-style)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_key_proj" -> "node_attn_key_shared";
  "node_attn_projections" -> "node_attn_key_proj";
  "node_attn_value_proj" [label="Value Projection", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_attn_value_per_head" [label="Per-head Values (MHA-style)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_value_proj" -> "node_attn_value_per_head";
  "node_attn_value_shared" [label="Shared Values (GQA/MQA-style)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_value_proj" -> "node_attn_value_shared";
  "node_attn_projections" -> "node_attn_value_proj";
  "node_attn_output_proj" [label="Output Projection", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_projections" -> "node_attn_output_proj";
  "node_transformer_attention" -> "node_attn_projections";
  "node_attn_compute" [label="Attention Computation", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_attn_softmax_impl" [label="Softmax Attention Implementation", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_attn_softmax_naive" [label="Naive / Standard Softmax", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_softmax_impl" -> "node_attn_softmax_naive";
  "node_attn_softmax_flash" [label="FlashAttention-style (Tiled)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
  "node_attn_softmax_impl" -> "node_attn_softmax_flash";
  "node_attn_compute" -> "node_attn_softmax_impl";
  "node_transformer_attention" -> "node_attn_compute";
  "node_attn_kv_cache" [label="KV Cache Strategy (Inference)", fillcolor="#fbbf24", width=1.8, height=0.6, fontsize=11, fontcolor="#f9fafb", penwidth=2];
  "node_kv_cache_none" [label="No KV Cache (Recompute)", fillcolor="#b45309", width=1.5, height=0.4, fontsize=9, fontcolor="#9ca3af", penwidth=1];
