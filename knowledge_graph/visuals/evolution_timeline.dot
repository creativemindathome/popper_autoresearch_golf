digraph Evolution {
  graph [bgcolor="#fafafa", fontname="Helvetica",
         fontsize=16, labelloc="t", labeljust="center",
         nodesep=0.4, ranksep=1.5, pad=1.0];
  node [fontname="Helvetica", shape=box, style="rounded,filled", penwidth=1.5];
  edge [color="#94a3b8", arrowsize=0.7, penwidth=1.2];

  label="Hypothesis Evolution Timeline";

  "h1_start" [label="H1: Entropy Guided Sparse Att\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h1_complete" [label="REFUTED\n(35.2s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h1_start" -> "h1_complete";
  "h2_start" [label="H2: Differential Attention Ro\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h2_complete" [label="REFUTED\n(40.8s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h2_start" -> "h2_complete";
  "h1_complete" -> "h2_start" [style="dashed", color="#94a3b860", constraint=false];
  "h3_start" [label="H3: Gradient Guided Sparse At\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h3_complete" [label="REFUTED\n(38.3s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h3_start" -> "h3_complete";
  "h2_complete" -> "h3_start" [style="dashed", color="#94a3b860", constraint=false];
  "h4_start" [label="H4: Fourier Attention Gates\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h4_complete" [label="REFUTED\n(32.2s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h4_start" -> "h4_complete";
  "h3_complete" -> "h4_start" [style="dashed", color="#94a3b860", constraint=false];
  "h5_start" [label="H5: Temporal Depth Modulation\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h5_complete" [label="REFUTED\n(35.8s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h5_start" -> "h5_complete";
  "h4_complete" -> "h5_start" [style="dashed", color="#94a3b860", constraint=false];
  "h6_start" [label="H6: Adaptive Sparse Moe 6\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h6_complete" [label="REFUTED\n(39.9s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h6_start" -> "h6_complete";
  "h5_complete" -> "h6_start" [style="dashed", color="#94a3b860", constraint=false];
  "h7_start" [label="H7: Gradient Informed Attenti\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h7_complete" [label="REFUTED\n(41.7s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h7_start" -> "h7_complete";
  "h6_complete" -> "h7_start" [style="dashed", color="#94a3b860", constraint=false];
  "h8_start" [label="H8: Gradient Conditioned Atte\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h8_complete" [label="REFUTED\n(37.9s)", fillcolor="#ef4444", fontcolor="white", width=1.2, height=0.5];
  "h8_start" -> "h8_complete";
  "h7_complete" -> "h8_start" [style="dashed", color="#94a3b860", constraint=false];
  "h9_start" [label="H9: Spiral Attention H9\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h9_complete" [label="None\n(28.7s)", fillcolor="#f59e0b", fontcolor="white", width=1.2, height=0.5];
  "h9_start" -> "h9_complete";
  "h8_complete" -> "h9_start" [style="dashed", color="#94a3b860", constraint=false];
  "h10_start" [label="H10: Fractal Depth Transformer\n(start)", fillcolor="#3b82f6", fontcolor="white", width=2.0, height=0.6];
  "h10_complete" [label="None\n(40.2s)", fillcolor="#f59e0b", fontcolor="white", width=1.2, height=0.5];
  "h10_start" -> "h10_complete";
  "h9_complete" -> "h10_start" [style="dashed", color="#94a3b860", constraint=false];
}