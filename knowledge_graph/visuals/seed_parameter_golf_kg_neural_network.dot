digraph KnowledgeGraph {
  graph [rankdir=LR, bgcolor="#ffffff", fontname="Helvetica", fontsize=10, labelloc="t", labeljust="l", nodesep="0.15", ranksep="0.25", splines="ortho", overlap="false", pad="0.1"];
  node [fontname="Helvetica", fontsize=10, margin="0.10,0.07"];
  edge [color="#adb5bd", arrowsize="0.6", penwidth="1"];

  label="Neural Network";

  "node_root_neural_network" [shape="box", style="rounded,filled,bold", fillcolor="#fff9db", color="#e67700", fontcolor="#212529", penwidth="2", label=<<B>Neural Network</B>>, tooltip="Defines the parameterized function that maps tokens to next-token probabilities. Under Parameter Golf, architecture choices must trade off accuracy against strict parameter and memory ceilings."];
  "node_nn_embeddings" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Embeddings</B>>, tooltip="Maps discrete tokens into continuous vectors the network can process. Embeddings often dominate parameter count in tiny LLMs because they scale with vocabulary size."];
  "node_nn_embedding_strategy" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Token Embedding Strategy</B>>, tooltip="Defines how token IDs are converted to vectors and how much parameter budget is allocated to that mapping. Changing this is a common way to free parameters for the backbone."];
  "node_embed_full" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Full Embedding Matrix</B><BR/><FONT POINT-SIZE="9">P:8,000,000 | Mem:12MB</FONT>>, tooltip="A learned lookup table mapping each vocabulary token to a dense vector. It is expressive but can consume a large fraction of the parameter budget."];
  "node_embed_factorized" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Factorized Embeddings</B><BR/><FONT POINT-SIZE="9">P:5,000,000 | Mem:12MB</FONT>>, tooltip="Represents embeddings as a low-rank factorization to reduce parameters while preserving expressivity. This trades some embedding capacity for parameter headroom."];
  "node_embed_hashing" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Hashed / Shared Embeddings</B><BR/><FONT POINT-SIZE="9">P:2,500,000 | Mem:10MB</FONT>>, tooltip="Maps multiple tokens to shared embedding slots via hashing or sharing rules to reduce parameters. This can free significant budget but may introduce collisions that hurt accuracy."];
  "node_nn_positional_encoding" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Positional Encoding</B>>, tooltip="Injects token position information so the model can distinguish order. Some methods are parameter-free but affect attention behavior and memory scaling with context length."];
  "node_pos_rope" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>RoPE (Rotary)</B><BR/><FONT POINT-SIZE="9">Mem:0.5MB</FONT>>, tooltip="Applies a deterministic rotation to query/key vectors based on position, enabling extrapolation to longer contexts. It is parameter-free and common in modern LLMs."];
  "node_pos_alibi" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>ALiBi (Linear Bias)</B><BR/><FONT POINT-SIZE="9">Mem:0.5MB</FONT>>, tooltip="Adds a head-dependent linear bias to attention logits that encodes relative positions. It is parameter-free and can improve long-context generalization under budget."];
  "node_pos_absolute" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Learned Absolute Positions</B><BR/><FONT POINT-SIZE="9">P:260,000 | Mem:0.8MB</FONT>>, tooltip="Uses a learned embedding for each position up to the context limit. It adds parameters proportional to context length and can be less robust to extrapolation."];
  "node_nn_transformer" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Transformer Backbone</B>>, tooltip="Stacks attention and feed-forward blocks to model complex token dependencies. Under Parameter Golf, most innovation lives in reallocating parameter/memory across these sub-components."];
  "node_transformer_block" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Transformer Block</B>>, tooltip="A repeated unit combining attention, MLP, normalization, and residual connections. Its internal design determines both parameter efficiency and activation/KV-cache memory."];
  "node_transformer_attention" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Attention</B>>, tooltip="Computes content-dependent mixing of token representations to model long-range interactions. Attention is memory-heavy due to attention logits/activations and KV cache during inference."];
  "node_attn_projections" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Attention Projections</B>>, tooltip="Linear layers that produce queries, keys, values, and output projections. Projection parameter count scales roughly with hidden size squared, making it a major budget lever."];
  "node_attn_query_proj" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Query Projection</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5MB</FONT>>, tooltip="Projects hidden states into query vectors used to retrieve information from keys/values. Its parameters scale with hidden size and number of layers."];
  "node_attn_key_proj" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Key Projection</B>>, tooltip="Projects hidden states into key vectors that index information in attention. Key projection can be per-head (more parameters) or shared across heads (fewer parameters)."];
  "node_attn_key_per_head" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Per-head Keys (MHA-style)</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5MB</FONT>>, tooltip="Computes distinct key vectors for each attention head, maximizing expressivity. This typically uses more parameters than shared-key variants."];
  "node_attn_key_shared" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Shared Keys (GQA/MQA-style)</B><BR/><FONT POINT-SIZE="9">P:120,000 | Mem:5MB</FONT>>, tooltip="Shares key projections across heads or head groups, reducing parameter count. It often trades some expressivity for large memory savings in KV cache during inference."];
  "node_attn_value_proj" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Value Projection</B>>, tooltip="Projects hidden states into value vectors that carry content aggregated by attention weights. Like keys, values can be per-head or shared to reduce parameters and KV cache."];
  "node_attn_value_per_head" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Per-head Values (MHA-style)</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5MB</FONT>>, tooltip="Computes distinct value vectors per head to maximize representational capacity. This uses more parameters and increases KV cache size compared to shared-value variants."];
  "node_attn_value_shared" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Shared Values (GQA/MQA-style)</B><BR/><FONT POINT-SIZE="9">P:120,000 | Mem:5MB</FONT>>, tooltip="Shares value projections across heads or head groups, reducing parameter count. It can significantly reduce inference KV cache memory at small parameter budgets."];
  "node_attn_output_proj" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Output Projection</B><BR/><FONT POINT-SIZE="9">P:400,000 | Mem:5MB</FONT>>, tooltip="Projects concatenated head outputs back to the model hidden size. It is required for standard multi-head attention and scales with hidden size squared."];
  "node_attn_compute" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Attention Computation</B>>, tooltip="Computes attention weights and applies them to values. The choice of implementation affects peak activation memory and speed, especially at longer context lengths."];
  "node_attn_softmax_impl" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Softmax Attention Implementation</B>>, tooltip="Determines how attention logits and softmax are computed and stored. Memory-efficient implementations can reduce peak activation memory without changing parameters."];
  "node_attn_softmax_naive" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Naive / Standard Softmax</B><BR/><FONT POINT-SIZE="9">Mem:40MB</FONT>>, tooltip="Materializes attention logits/weights more directly, increasing activation memory at long context. It is widely supported but often memory-limited in Parameter Golf settings."];
  "node_attn_softmax_flash" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>FlashAttention-style (Tiled)</B><BR/><FONT POINT-SIZE="9">Mem:18MB</FONT>>, tooltip="Computes attention in tiles to avoid storing full attention matrices. This can sharply reduce peak activation memory while preserving standard softmax attention."];
  "node_attn_kv_cache" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>KV Cache Strategy (Inference)</B>>, tooltip="Stores past keys/values for autoregressive decoding to avoid recomputation. KV cache memory scales with context length and head dimensions, often dominating inference memory."];
  "node_kv_cache_none" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>No KV Cache (Recompute)</B>>, tooltip="Does not store past keys/values, recomputing them each step. This reduces memory but increases compute and can be infeasible for long contexts."];
  "node_kv_cache_fp16" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>FP16/BF16 KV Cache</B><BR/><FONT POINT-SIZE="9">Mem:24MB</FONT>>, tooltip="Stores keys/values in half precision, balancing fidelity and memory usage. This is a common baseline for inference memory accounting."];
  "node_kv_cache_int8" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>INT8 KV Cache</B><BR/><FONT POINT-SIZE="9">Mem:12MB</FONT>>, tooltip="Quantizes KV cache to 8-bit representations to reduce memory footprint. This can introduce approximation error but may be critical under strict memory budgets."];
  "node_transformer_mlp" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Feed-Forward Network (MLP)</B>>, tooltip="Applies per-token nonlinear transformations that expand and contract hidden representations. MLP layers often dominate parameter count and a large share of activation memory."];
  "node_mlp_variant" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>MLP Variant</B>>, tooltip="Chooses the internal structure of the MLP (activation, gating, sparsity, or factorization). This is a prime target for parameter reallocation toward OOD ideas."];
  "node_mlp_dense_fnn" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Dense FFN (ReLU/GELU)</B><BR/><FONT POINT-SIZE="9">P:4,200,000 | Mem:70MB</FONT>>, tooltip="Standard two-layer feed-forward network with a pointwise nonlinearity. It is a strong baseline but uses many parameters for a given hidden size."];
  "node_mlp_swiglu" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>SwiGLU (Gated MLP)</B><BR/><FONT POINT-SIZE="9">P:5,200,000 | Mem:80MB</FONT>>, tooltip="Uses a gated activation that can improve quality at fixed depth. It often increases parameters slightly versus a dense FFN but can be more compute-efficient per gain."];
  "node_mlp_low_rank" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Low-rank / Factorized MLP</B><BR/><FONT POINT-SIZE="9">P:2,500,000 | Mem:55MB</FONT>>, tooltip="Factorizes large MLP matrices into low-rank components to reduce parameters. This can free budget for attention or new modules but may bottleneck capacity."];
  "node_mlp_moe" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Mixture-of-Experts (Sparse)</B><BR/><FONT POINT-SIZE="9">P:8,000,000 | Mem:90MB</FONT>>, tooltip="Routes tokens to a subset of expert MLPs, increasing total parameters without proportional compute. It can boost capacity but complicates routing and memory accounting."];
  "node_transformer_norm" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Normalization</B>>, tooltip="Stabilizes activations and gradients to enable deep training. Normalization has low parameter cost but strongly affects optimization dynamics in small models."];
  "node_norm_layernorm" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>LayerNorm</B><BR/><FONT POINT-SIZE="9">P:10,000 | Mem:1MB</FONT>>, tooltip="Normalizes activations using mean and variance across hidden dimensions with learned gain/bias. It is widely used but can be slower than RMSNorm in some kernels."];
  "node_norm_rmsnorm" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>RMSNorm</B><BR/><FONT POINT-SIZE="9">P:8,000 | Mem:0.8MB</FONT>>, tooltip="Normalizes by root-mean-square without subtracting the mean, typically using only a learned gain. It can be more parameter- and compute-efficient while remaining stable."];
  "node_transformer_residual" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Residual Connections</B><BR/><FONT POINT-SIZE="9">Mem:1MB</FONT>>, tooltip="Adds skip connections that improve gradient flow and allow iterative refinement of representations. Residuals add negligible parameters but contribute to activation storage."];
  "node_transformer_dropout" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Dropout</B><BR/><FONT POINT-SIZE="9">Mem:0.5MB</FONT>>, tooltip="Randomly zeroes activations during training to reduce overfitting. It has no parameters but can change optimization behavior and effective capacity in tiny models."];
  "node_nn_output_head" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>Output Head</B>>, tooltip="Maps final hidden states to logits over the vocabulary. The output layer can match embedding size and may rival embeddings in parameter cost unless weights are tied or factorized."];
  "node_head_strategy" [shape="box", style="rounded,filled", fillcolor="#e7f5ff", color="#1971c2", fontcolor="#212529", penwidth="1.4", label=<<B>LM Head Strategy</B>>, tooltip="Defines how logits are produced, including whether the head is untied, tied to embeddings, or structured to reduce parameters. This is a common place to free parameters under strict budgets."];
  "node_head_untied" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Untied Linear LM Head</B><BR/><FONT POINT-SIZE="9">P:8,000,000 | Mem:10MB</FONT>>, tooltip="Uses a separate weight matrix to map hidden states to vocabulary logits. This maximizes flexibility but can nearly double parameters when embeddings are also large."];
  "node_head_weight_tied" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Weight-tied Head (Reuse Embeddings)</B><BR/><FONT POINT-SIZE="9">Mem:2MB</FONT>>, tooltip="Reuses the token embedding matrix as the output projection, reducing parameters and sometimes improving generalization. This is a high-leverage Parameter Golf trick."];
  "node_head_adaptive_softmax" [shape="box", style="rounded,filled", fillcolor="#f8f9fa", color="#495057", fontcolor="#212529", penwidth="1", label=<<B>Adaptive / Factorized Softmax</B><BR/><FONT POINT-SIZE="9">P:4,000,000 | Mem:8MB</FONT>>, tooltip="Structures the output distribution to reduce compute and parameters for rare tokens. It can save parameters but adds complexity and may affect benchmark comparability."];

  "node_root_neural_network" -> "node_nn_embeddings" [];
  "node_nn_embeddings" -> "node_nn_embedding_strategy" [];
  "node_nn_embedding_strategy" -> "node_embed_full" [];
  "node_nn_embedding_strategy" -> "node_embed_factorized" [];
  "node_nn_embedding_strategy" -> "node_embed_hashing" [];
  "node_nn_embeddings" -> "node_nn_positional_encoding" [];
  "node_nn_positional_encoding" -> "node_pos_rope" [];
  "node_nn_positional_encoding" -> "node_pos_alibi" [];
  "node_nn_positional_encoding" -> "node_pos_absolute" [];
  "node_root_neural_network" -> "node_nn_transformer" [];
  "node_nn_transformer" -> "node_transformer_block" [];
  "node_transformer_block" -> "node_transformer_attention" [];
  "node_transformer_attention" -> "node_attn_projections" [];
  "node_attn_projections" -> "node_attn_query_proj" [];
  "node_attn_projections" -> "node_attn_key_proj" [];
  "node_attn_key_proj" -> "node_attn_key_per_head" [];
  "node_attn_key_proj" -> "node_attn_key_shared" [];
  "node_attn_projections" -> "node_attn_value_proj" [];
  "node_attn_value_proj" -> "node_attn_value_per_head" [];
  "node_attn_value_proj" -> "node_attn_value_shared" [];
  "node_attn_projections" -> "node_attn_output_proj" [];
  "node_transformer_attention" -> "node_attn_compute" [];
  "node_attn_compute" -> "node_attn_softmax_impl" [];
  "node_attn_softmax_impl" -> "node_attn_softmax_naive" [];
  "node_attn_softmax_impl" -> "node_attn_softmax_flash" [];
  "node_transformer_attention" -> "node_attn_kv_cache" [];
  "node_attn_kv_cache" -> "node_kv_cache_none" [];
  "node_attn_kv_cache" -> "node_kv_cache_fp16" [];
  "node_attn_kv_cache" -> "node_kv_cache_int8" [];
  "node_transformer_block" -> "node_transformer_mlp" [];
  "node_transformer_mlp" -> "node_mlp_variant" [];
  "node_mlp_variant" -> "node_mlp_dense_fnn" [];
  "node_mlp_variant" -> "node_mlp_swiglu" [];
  "node_mlp_variant" -> "node_mlp_low_rank" [];
  "node_mlp_variant" -> "node_mlp_moe" [];
  "node_transformer_block" -> "node_transformer_norm" [];
  "node_transformer_norm" -> "node_norm_layernorm" [];
  "node_transformer_norm" -> "node_norm_rmsnorm" [];
  "node_transformer_block" -> "node_transformer_residual" [];
  "node_transformer_block" -> "node_transformer_dropout" [];
  "node_root_neural_network" -> "node_nn_output_head" [];
  "node_nn_output_head" -> "node_head_strategy" [];
  "node_head_strategy" -> "node_head_untied" [];
  "node_head_strategy" -> "node_head_weight_tied" [];
  "node_head_strategy" -> "node_head_adaptive_softmax" [];
}
