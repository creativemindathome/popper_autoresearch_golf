+class LayerGating(nn.Module):
+    def __init__(self, dim: int):
+        super().__init__()
+        # Initialize scale to ones and shift to zeros for identity transformation at start
+        self.scale = nn.Parameter(torch.ones(dim, dtype=torch.float32))
+        self.shift = nn.Parameter(torch.zeros(dim, dtype=torch.float32))
+
+    def forward(self, x: Tensor) -> Tensor:
+        return x * self.scale.to(dtype=x.dtype) + self.shift.to(dtype=x.dtype)
