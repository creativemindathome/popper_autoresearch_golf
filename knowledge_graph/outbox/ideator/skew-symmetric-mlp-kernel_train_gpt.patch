+class SkewSymmetricMLPLinear(nn.Module):
+    def __init__(self, in_features: int, out_features: int, bias: bool, basis_rank: int):
+        super().__init__()
+        self.in_features = in_features
+        self.out_features = out_features
+        self.bias = nn.Parameter(torch.zeros(out_features, dtype=torch.float32)) if bias else None
+        self.basis_rank = basis_rank
+
+        # Learnable parameters for the projections and skew-symmetric core
+        # P_in: in_features x basis_rank
+        # S_base: basis_rank x basis_rank
+        # P_out: basis_rank x out_features
+        self.P_in = nn.Parameter(torch.empty(in_features, basis_rank, dtype=torch.float32))
+        self.S_base = nn.Parameter(torch.empty(basis_rank, basis_rank, dtype=torch.float32))
+        self.P_out = nn.Parameter(torch.empty(basis_rank, out_features, dtype=torch.float32))
+
+        self.reset_parameters()
+
+    def reset_parameters(self):
+        # Initialize P_in, P_out with Kaiming uniform
+        nn.init.kaiming_uniform_(self.P_in, a=math.sqrt(5))
+        nn.init.kaiming_uniform_(self.P_out, a=math.sqrt(5))
+        # Initialize S_base with small random values
+        nn.init.uniform_(self.S_base, -1e-3, 1e-3)
+        if self.bias is not None:
+            nn.init.zeros_(self.bias)
+
+    def forward(self, x: Tensor) -> Tensor:
+        S_core = self.S_base - self.S_base.T  # Enforce skew-symmetry
+        Q = torch.matrix_exp(S_core)          # Generate orthogonal matrix
+
+        # Construct the effective weight matrix: (in_features x basis_rank) @ (basis_rank x basis_rank) @ (basis_rank x out_features) = in_features x out_features
+        effective_weight = self.P_in.to(x.dtype) @ Q.to(x.dtype) @ self.P_out.to(x.dtype)
+
+        # Apply linear transformation (analogous to Conv1D's forward)
+        output = F.linear(x, effective_weight, self.bias.to(x.dtype) if self.bias is not None else None)
+        return output
+
